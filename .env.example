# daily-market-radar — optional secrets / configuration.
# Copy to .env for local use. WITHOUT any of these, deterministic mode still runs,
# the website is still generated, Pages still deploys, and unavailable integrations
# are disclosed as coverage gaps. NEVER commit real values.

# --- OpenAI (optional; enables auto / api-assisted evaluation) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_DAILY_COST_USD=0
OPENAI_MAX_ITEMS_PER_RUN=0
OPENAI_MAX_INPUT_TOKENS_PER_RUN=0

# --- FreshRSS collection (optional) ---
FRESHRSS_BASE_URL=
FRESHRSS_USERNAME=
FRESHRSS_API_PASSWORD=

# --- Durable state (optional external backend; default is the radar-state branch) ---
DATABASE_URL=

# --- Runtime ---
RADAR_EVALUATION_MODE=auto
