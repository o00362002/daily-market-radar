{
  "version": "0.1",
  "last_updated": "2026-07-07",
  "status": "active_draft",
  "purpose": "Registry for direct RSS feeds and RSSHub route candidates used by the feed discovery stack. RSSHub paths must be verified before they count as checked sources.",
  "rsshub": {
    "base_url_env": "RSSHUB_BASE_URL",
    "default_local_base_url": "http://localhost:1200",
    "internal_docker_base_url": "http://rsshub:1200",
    "route_verification_required": true
  },
  "freshrss": {
    "base_url_env": "FRESHRSS_BASE_URL",
    "category_prefix": "daily-market-radar",
    "import_format": "opml"
  },
  "feeds": [
    {
      "source_id": "rsshub_project_github",
      "name": "RSSHub GitHub project",
      "domain_ids": ["ai_agents_workflow", "technology_development"],
      "region": "global",
      "languages": ["en", "zh"],
      "feed_kind": "rsshub_route_candidate",
      "rsshub_path": "/github/repos/DIYgod/RSSHub/releases",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "medium_low",
      "use_for": ["rsshub_release_monitoring", "route_change_awareness"],
      "verification_rule": "verify_route_before_counting; project updates are not market evidence by themselves"
    },
    {
      "source_id": "youtube_channel_route_template",
      "name": "RSSHub YouTube channel route template",
      "domain_ids": ["ai_agents_workflow", "retail_consumer_social_fashion", "technology_development"],
      "region": "global",
      "languages": ["multi"],
      "feed_kind": "rsshub_route_template",
      "rsshub_path_template": "/youtube/channel/{channel_id}",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "medium_low",
      "use_for": ["youtube_first_sources", "product_demo_channels", "conference_demo_channels"],
      "verification_rule": "replace channel_id and verify route response before use"
    },
    {
      "source_id": "telegram_channel_route_template",
      "name": "RSSHub Telegram channel route template",
      "domain_ids": ["crypto_rwa_agent_payments", "global_markets_capital_geopolitics"],
      "region": "global",
      "languages": ["multi"],
      "feed_kind": "rsshub_route_template",
      "rsshub_path_template": "/telegram/channel/{channel}",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "low",
      "use_for": ["public_telegram_announcements", "crypto_project_updates", "market_narrative_monitoring"],
      "verification_rule": "public channels only; verify official identity; cross-check major claims"
    },
    {
      "source_id": "instagram_public_route_template",
      "name": "RSSHub Instagram public account route template",
      "domain_ids": ["crypto_rwa_agent_payments", "retail_consumer_social_fashion", "labor_consumption_taiwan"],
      "region": "multi",
      "languages": ["multi"],
      "feed_kind": "rsshub_route_template",
      "rsshub_path_template": "verify_in_RSSHub_docs_before_use",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "low",
      "use_for": ["instagram_first_sources", "mall_brand_posts", "taiwan_crypto_social_posts"],
      "verification_rule": "only public content; if route cannot be verified, mark social_channel_unchecked"
    },
    {
      "source_id": "threads_public_route_template",
      "name": "RSSHub Threads public account route template",
      "domain_ids": ["ai_agents_workflow", "retail_consumer_social_fashion", "labor_consumption_taiwan"],
      "region": "multi",
      "languages": ["multi"],
      "feed_kind": "rsshub_route_template",
      "rsshub_path_template": "verify_in_RSSHub_docs_before_use",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "low",
      "use_for": ["threads_first_sources", "creator_economy_posts", "social_commerce_posts"],
      "verification_rule": "only public content; verify with stronger source types for claims"
    },
    {
      "source_id": "direct_rss_official_newsroom_template",
      "name": "Direct RSS official newsroom template",
      "domain_ids": ["ai_agents_workflow", "global_markets_capital_geopolitics", "technology_development", "retail_consumer_social_fashion"],
      "region": "multi",
      "languages": ["multi"],
      "feed_kind": "direct_rss_template",
      "feed_url_template": "https://example.com/rss.xml",
      "route_status": "needs_route_verification",
      "enabled_for_opml": false,
      "evidence_default": "high_when_official",
      "use_for": ["company_newsroom", "regulator_updates", "official_blog"],
      "verification_rule": "replace feed_url_template with official RSS/Atom URL and verify usage policy"
    }
  ],
  "audit_rules": {
    "enabled_items_must_have": ["source_id", "name", "domain_ids", "feed_kind", "route_status", "evidence_default", "verification_rule"],
    "rsshub_route_candidates_count_as_checked_only_when": "route_status == verified AND enabled_for_opml == true",
    "templates_count_as_checked": false,
    "social_first_claims_need_crosscheck": true
  }
}
