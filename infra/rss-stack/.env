# daily-market-radar RSS stack local settings
# Copy to .env before running docker compose.

TZ=Asia/Taipei

RSSHUB_PORT=1200
RSSHUB_BASE_URL=http://localhost:1200

FRESHRSS_PORT=8080
FRESHRSS_BASE_URL=http://localhost:8080
FRESHRSS_DEFAULT_USER=admin
FRESHRSS_ADMIN_EMAIL=admin@example.local
FRESHRSS_ADMIN_PASSWORD=Wantheart5*
FRESHRSS_API_PASSWORD=Wantheart55*
FRESHRSS_CRON_MIN=2,32


