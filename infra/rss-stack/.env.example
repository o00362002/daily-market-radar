# daily-market-radar RSS stack local settings
# Copy to .env before running docker compose.

TZ=Asia/Taipei

RSSHUB_IMAGE=diygod/rsshub:2024-07-07
BROWSERLESS_IMAGE=browserless/chrome:1.61-chrome-stable
REDIS_IMAGE=redis:7.2-alpine
FRESHRSS_IMAGE=freshrss/freshrss:1.25.0

RSSHUB_PORT=1200
RSSHUB_BASE_URL=http://localhost:1200

FRESHRSS_PORT=8080
FRESHRSS_BASE_URL=http://localhost:8080
FRESHRSS_DEFAULT_USER=admin
FRESHRSS_ADMIN_EMAIL=admin@example.local
FRESHRSS_ADMIN_PASSWORD=change-me-admin-password
FRESHRSS_API_PASSWORD=change-me-api-password
FRESHRSS_CRON_MIN=2,32
