---
import { marked } from 'marked';
import Base from '../../layouts/Base.astro';
import { allLegacyEntries, getLegacyMarkdown } from '../../lib/data';

export function getStaticPaths() {
  return allLegacyEntries().map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}
const { entry } = Astro.props as any;
const markdown = getLegacyMarkdown(entry.markdown_path) ?? '';
// Build-time conversion of trusted in-repo markdown; no client JS involved.
const html = marked.parse(markdown, { async: false }) as string;
const base = import.meta.env.BASE_URL;
const rawHref = `${base}${base.endsWith('/') ? '' : '/'}data/${entry.markdown_path}`;
---
<Base title={`歸檔 ${entry.date}`}>
  <p class="badge fixture"><span class="sym">⚠</span> 對話歸檔（人工報告），非 validated RadarReportV2。</p>
  <article class="legacy-md" set:html={html} />
  <p><a href={rawHref}>原始 Markdown ↗</a></p>
</Base>
