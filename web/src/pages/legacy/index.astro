---
import Base from '../../layouts/Base.astro';
import { allLegacyEntries } from '../../lib/data';

const entries = allLegacyEntries();
const base = import.meta.env.BASE_URL;
const href = (slug: string) => `${base}${base.endsWith('/') ? '' : '/'}legacy/${slug}`;
---
<Base title="歸檔 Legacy Reports">
  <h1>歸檔 · 舊版每日報告</h1>
  <p class="badge fixture"><span class="sym">⚠</span> 對話歸檔（人工／對話產出報告），非 validated RadarReportV2 投影；機器驗證的歷史自 2026-07-11 起。</p>
  {entries.length === 0 && <p class="empty">尚無歸檔報告（export 時未帶 --legacy-reports-dir）。</p>}
  {entries.length > 0 && (
    <table>
      <thead><tr><th>日期</th><th>標題</th><th>變體</th></tr></thead>
      <tbody>
        {entries.map((e) => (
          <tr>
            <td><a href={href(e.slug)}>{e.date}</a></td>
            <td><a href={href(e.slug)}>{e.title}</a></td>
            <td class="muted">{e.variant || '—'}</td>
          </tr>
        ))}
      </tbody>
    </table>
  )}
</Base>
