---
import '../styles/global.css';
interface Props { title?: string; }
const { title = '全球情報雷達 Daily Market Radar' } = Astro.props;
const base = import.meta.env.BASE_URL;
const nav = [
  ['今日 Today', ''],
  ['歷史 History', 'history/1'],
  ['趨勢 Trends', 'trends'],
  ['零售 Retail', 'retail'],
  ['加密 Crypto', 'crypto'],
  ['台灣 Taiwan', 'taiwan'],
];
const href = (path: string) => `${base}${base.endsWith('/') ? '' : '/'}${path}`.replace(/\/+$/, '/') ;
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content="全球每日事件情報雷達與多領域趨勢／潛力訊號掃描" />
  </head>
  <body>
    <header class="site">
      <div class="wrap">
        <nav>
          <span class="brand"><a href={href('')}>◎ 情報雷達</a></span>
          {nav.map(([label, path]) => <a href={href(path)}>{label}</a>)}
        </nav>
      </div>
    </header>
    <main class="wrap">
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        靜態投影自 validated RadarReportV2 · 事實／推論／反證／不確定／缺口分開標示 · 數量不是完整性證明
      </div>
    </footer>
  </body>
</html>
